# fa.reel — Environment Variables
# Copy to .env and fill in values before running docker-compose.

# PostgreSQL (pgvector/pgvector:pg16)
POSTGRES_USER=reel
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=reel

# Backend API
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=reel;Username=reel;Password=REPLACE_WITH_STRONG_DB_PASSWORD
Database__AutoMigrateOnStartup=true

# JWT / app session (Sign in with Trakt mints these; fa.startup naming)
JWT_SECRET=REPLACE_WITH_MIN_32_CHAR_SECRET_VALUE
JWT_ISSUER=frostaura-reel
JWT_AUDIENCE=frostaura-reel-app
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30

# Trakt — create an app at https://trakt.tv/oauth/applications
# Redirect URIs: https://reel.frostaura.net/auth/trakt/callback (prod)
#                http://localhost:5173/auth/trakt/callback (dev)
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=http://localhost:5173/auth/trakt/callback
TRAKT_RATE_BUDGET_PER_5MIN=900
TRAKT_POST_BUDGET_PER_SEC=1
# Dev/test profile
TRAKT_DEV_PROFILE=deanmar09

# TMDB — https://www.themoviedb.org/settings/api (use the v4 Read Access Token)
TMDB_READ_ACCESS_TOKEN=
TMDB_RATE_PER_SEC=40

# OpenRouter (LLM gateway — per-title attribute extraction; fa.startup naming)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_CONCURRENCY=4

# Embeddings — local = in-process ONNX MiniLM (default); openrouter = remote /embeddings
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
EMBEDDINGS_DIMENSIONS=384

# Sync cadence
SYNC_DELTA_MINUTES=15
SYNC_HOT_MINUTES=5
RETRAIN_MIN_NEW_RATINGS=10

# Region default when the CF-IPCountry header is absent (dev)
GEOIP_DEFAULT_REGION=US

# Web
APP_PUBLIC_URL=http://localhost:8090
CORS_ALLOWED_ORIGINS=http://localhost:8090,http://localhost:5173

# Test helpers — deterministic LLM stub (never hits the network when true)
TestHelpers__ModelStubMode=false

# Gateway (nginx reverse proxy)
GATEWAY_PORT=8090
NGINX_BACKEND_PORT=5000
NGINX_FRONTEND_PORT=80
NGINX_CLIENT_MAX_BODY_SIZE=10m

# Frontend dev
VITE_API_TARGET=http://127.0.0.1:5000

# CI/deploy (GitHub repo secrets, not local env): DOCKERHUB_USERNAME, DOCKERHUB_TOKEN,
# PORTAINER_URL, PORTAINER_TOKEN, PORTAINER_ENDPOINT_ID, PORTAINER_STACK_ID
